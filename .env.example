PORT=3001
FRONTEND_URL=https://the-app-pi.vercel.app
JWT_SECRET=replace_with_strong_secret

MYSQL_ADDON_HOST=your-host
MYSQL_ADDON_PORT=3306
MYSQL_ADDON_DB=your-db
MYSQL_ADDON_USER=your-user
MYSQL_ADDON_PASSWORD=your-password

# Optional fallback names
DB_HOST=your-host
DB_PORT=3306
DB_NAME=your-db
DB_USER=your-user
DB_PASS=your-password

# Set to false only if your provider requires non-SSL
DB_SSL=true

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
